# ── App ───────────────────────────────────────
APP_VERSION=1.0.0
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO
PORT=8001

# ── Database ──────────────────────────────────
DATABASE_PATH=./data/rbac_security.db
MIGRATIONS_DIR=./migrations

# ── Ollama LLM (local on host machine) ────────
# From Docker container, use host.docker.internal (mapped to host-gateway)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT=60.0
OLLAMA_MAX_RETRIES=3
OLLAMA_NUM_GPU=0

# ── Security ──────────────────────────────────
API_KEY_HEADER=X-API-Key
DEFAULT_RATE_LIMIT=100
RATE_LIMIT_WINDOW=60

# ── Threat Scoring ────────────────────────────
THREAT_SCORE_ROOT=50
THREAT_SCORE_FRIDA=80
THREAT_SCORE_DEBUGGER=40
THREAT_SCORE_TAMPER=60
THREAT_SCORE_EMULATOR=30
THREAT_SCORE_VPN=15
THREAT_SCORE_PROXY=20
THREAT_SCORE_OVERLAY=25
THREAT_SCORE_ACCESSIBILITY=25
THREAT_SCORE_HOOK=70
THREAT_SCORE_LOCATION_SPOOF=35
THREAT_SCORE_TIME_SPOOF=30
THREAT_SCORE_MALWARE=90
THREAT_SCORE_SCREENSHOT=10

# COPY THIS FILE TO .env AND FILL REAL VALUES
# NEVER COMMIT .env TO GIT
